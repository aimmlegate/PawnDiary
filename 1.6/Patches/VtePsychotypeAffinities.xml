          <memberBonuses><li><target>DiaryPsychotype_Narcissistic</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Theatrical</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Tycoon</traitDefName><key>VTE_Tycoon</key>
          <familyBonuses><li><target>grounded</target><bonus>2</bonus></li><li><target>intense</target><bonus>2</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Ambitious</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Pragmatic</target><bonus>2</bonus></li></memberBonuses>
        </li>
      </value>
    </match>
  </Operation>
</Patch>
