<?xml version="1.0" encoding="utf-8"?>
<!--
  Give twenty clearly outlook-shaped Vanilla Traits Expanded traits a data-only pull on Pawn
  Diary's existing psychotype roll. PatchOperationFindMod matches the target mod's display name;
  success=Always keeps this file silent and inert when VTE is absent. Every target below is an
  existing core family or DiaryPsychotypeDef, so removing VTE later cannot leave a dangling saved
  psychotype. Purely mechanical/biome/body traits were reviewed and deliberately left unmapped.
-->
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Vanilla Traits Expanded</li>
    </mods>
    <success>Always</success>
    <match Class="PatchOperationAdd">
      <xpath>/Defs/PawnDiary.DiaryPsychotypeTraitPolicyDef[defName="Diary_PsychotypeTraitPolicy"]/rules</xpath>
      <value>
        <li><traitDefName>VTE_Vengeful</traitDefName><key>VTE_Vengeful</key>
          <familyBonuses><li><target>intense</target><bonus>2</bonus></li><li><target>anxious</target><bonus>2</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Resentful</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Ruthless</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Kleptomaniac</traitDefName><key>VTE_Kleptomaniac</key>
          <familyBonuses><li><target>intense</target><bonus>2</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Ruthless</target><bonus>2</bonus></li><li><target>DiaryPsychotype_Wry</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_MadSurgeon</traitDefName><key>VTE_MadSurgeon</key>
          <familyBonuses><li><target>intense</target><bonus>4</bonus></li><li><target>inward</target><bonus>2</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Ruthless</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Detached</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Perfectionist</traitDefName><key>VTE_Perfectionist</key>
          <familyBonuses><li><target>anxious</target><bonus>4</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Perfectionist</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Dutiful</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Coward</traitDefName><key>VTE_Coward</key>
          <familyBonuses><li><target>anxious</target><bonus>4</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Avoidant</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Dependent</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Brave</traitDefName><key>VTE_Brave</key>
          <familyBonuses><li><target>grounded</target><bonus>4</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Pragmatic</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Dutiful</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Wanderlust</traitDefName><key>VTE_Wanderlust</key>
          <familyBonuses><li><target>grounded</target><bonus>2</bonus></li></familyBonuses>
          <memberBonuses><li><target>DiaryPsychotype_Ambitious</target><bonus>2</bonus></li><li><target>DiaryPsychotype_Nostalgic</target><bonus>2</bonus></li></memberBonuses>
        </li>
        <li><traitDefName>VTE_Insomniac</traitDefName><key>VTE_Insomniac</key>
