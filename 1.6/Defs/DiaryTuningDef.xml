<?xml version="1.0" encoding="utf-8"?>
<!--
  Tuning knobs for Pawn Diary. Edit a value and restart the game to retune behavior WITHOUT
  recompiling (see DiaryTuningDef.cs for what each field means). Every value here equals the
  code default, so deleting this file or omitting a field changes nothing.
-->
<Defs>

  <PawnDiary.DiaryTuningDef>
    <defName>Diary_Tuning</defName>

<!-- Deduplication windows (game ticks; 60 ticks ≈ 1 second) -->
    <socialFightDedupTicks>300</socialFightDedupTicks>
    <mentalBreakDedupTicks>2500</mentalBreakDedupTicks>
    <taleDedupTicks>2500</taleDedupTicks>
    <moodEventDedupTicks>2500</moodEventDedupTicks>
    <thoughtDedupTicks>2500</thoughtDedupTicks>
    <romanceDedupTicks>2500</romanceDedupTicks>
    <raidDedupTicks>2500</raidDedupTicks>
    <questDedupTicks>2500</questDedupTicks>

    <!-- Surroundings scan -->
    <!-- nearbyRadius: search radius in cells around pawn for notable objects -->
    <nearbyRadius>5</nearbyRadius>
    <!-- maxNearbyThings: candidate cap before weighted random pick -->
    <maxNearbyThings>6</maxNearbyThings>
    <coldBelowC>0</coldBelowC>
    <hotAboveC>32</hotAboveC>

    <!-- Weather mentions. Chance (0..1) an outdoor entry mentions the current weather, per weather.
         Clear is 0 (never noted); mild weather low, dramatic weather high, so weather stops
         dominating diary openings. Weathers not listed use the favorability fallbacks below, so
         DLC/modded weather still scales with severity. Keyed by WeatherDef.defName. -->
    <weatherMentionChances>
      <li><weather>Clear</weather><chance>0</chance></li>
      <li><weather>Overcast</weather><chance>0.2</chance></li>        <!-- Odyssey -->
      <li><weather>Fog</weather><chance>0.25</chance></li>
      <li><weather>SnowGentle</weather><chance>0.3</chance></li>
      <li><weather>Rain</weather><chance>0.35</chance></li>
      <li><weather>Windy</weather><chance>0.45</chance></li>          <!-- Odyssey -->
      <li><weather>FoggyRain</weather><chance>0.45</chance></li>
      <li><weather>BlindFog</weather><chance>0.6</chance></li>        <!-- Odyssey -->
      <li><weather>SnowHard</weather><chance>0.7</chance></li>
      <li><weather>ToxRain</weather><chance>0.85</chance></li>        <!-- Odyssey -->
      <li><weather>TorrentialRain</weather><chance>0.85</chance></li> <!-- Odyssey -->
      <li><weather>DryThunderstorm</weather><chance>0.9</chance></li>
      <li><weather>RainyThunderstorm</weather><chance>0.9</chance></li>
      <li><weather>Sandstorm</weather><chance>0.9</chance></li>       <!-- Odyssey -->
      <li><weather>Blizzard</weather><chance>0.95</chance></li>       <!-- Odyssey -->
      <li><weather>BloodRain</weather><chance>1</chance></li>         <!-- Anomaly -->
      <li><weather>GrayPall</weather><chance>1</chance></li>          <!-- Anomaly -->
      <li><weather>DeathPall</weather><chance>1</chance></li>         <!-- Anomaly -->
    </weatherMentionChances>
    <!-- Fallbacks for weathers not listed above, by WeatherDef.favorability. -->
    <weatherChanceVeryBad>0.9</weatherChanceVeryBad>
    <weatherChanceBad>0.5</weatherChanceBad>
    <weatherChanceNeutral>0.25</weatherChanceNeutral>
    <weatherChanceDefault>0</weatherChanceDefault>

    <!-- Health -->
    <painVisibleAbove>0.03</painVisibleAbove>
    <bleedVisibleAbove>0.01</bleedVisibleAbove>
    <lowCapacityThreshold>0.80</lowCapacityThreshold>

    <!-- Misc -->
    <diaryLineMaxChars>160</diaryLineMaxChars>
    <!-- Minimum biological age for first-person diary ownership/generation. Pre-teen colonists can
         still appear as context in someone else's entry, but do not write their own pages. -->
    <minimumFirstPersonAgeYears>13</minimumFirstPersonAgeYears>

    <!-- Beauty buckets -->
    <beautyBeautiful>2</beautyBeautiful>
    <beautyPleasant>0.3</beautyPleasant>
    <beautyUgly>-2</beautyUgly>

    <!-- Mood buckets (percent) -->
    <moodHappy>75</moodHappy>
    <moodStable>50</moodStable>
    <moodStressed>30</moodStressed>

    <!-- Pain buckets (fraction) -->
    <painSevere>0.4</painSevere>
    <painModerate>0.18</painModerate>

    <!-- Opinion buckets (opinion points) -->
    <opinionDevoted>60</opinionDevoted>
    <opinionFriendly>25</opinionFriendly>
    <opinionNeutralAbove>-10</opinionNeutralAbove>
    <opinionStrainedAbove>-40</opinionStrainedAbove>

    <!-- Thought recording thresholds -->
    <thoughtMinMoodOffset>5</thoughtMinMoodOffset>
    <thoughtEatingMinMoodOffset>15</thoughtEatingMinMoodOffset>

    <!-- Thoughts to always ignore (substring match in defName) -->
    <thoughtIgnoreTokens>
      <li>Room</li>
      <li>Environment</li>
      <li>ObservedCorpse</li>
    </thoughtIgnoreTokens>

    <!-- Thoughts that bypass magnitude threshold (always recorded if they have duration) -->
    <thoughtBypassThresholdTokens>
      <li>Death</li>
      <li>Died</li>
      <li>Killed</li>
      <li>Executed</li>
      <li>Banished</li>
      <li>Abandoned</li>
    </thoughtBypassThresholdTokens>

    <!-- Thoughts classified as eating-related (use higher threshold) -->
    <thoughtEatingTokens>
      <li>Ate</li>
      <li>Food</li>
      <li>Meal</li>
      <li>Cannibalism</li>
      <li>RawFood</li>
    </thoughtEatingTokens>

    <!-- Temporary thoughts folded into one ambient day note instead of immediate entries -->
    <thoughtAmbientTokens>
      <li>Nuzzled</li>
      <li>KindWordsMood</li>
      <li>InsultedMood</li>
      <li>AttendedParty</li>
      <li>AttendedConcert</li>
      <li>HeldConcert</li>
      <li>EncouragingSpeech</li>
      <li>InspirationalSpeech</li>
      <li>TerribleSpeech</li>
      <li>SleptInBarracks</li>
      <li>ObservedLayingRottingCorpse</li>
    </thoughtAmbientTokens>
    <thoughtAmbientWindowTicks>60000</thoughtAmbientWindowTicks>
    <thoughtAmbientMinEventsToWrite>2</thoughtAmbientMinEventsToWrite>
    <thoughtAmbientMaxSampleLines>5</thoughtAmbientMaxSampleLines>

    <!-- Situational thought progression scanner. These thoughts are active need/environment
         stages, not temporary memories, so they are scanned by current stage. Severity is ordered
         low -> high even when the vanilla stage list is not. -->
    <thoughtProgressionScanIntervalTicks>250</thoughtProgressionScanIntervalTicks>
    <thoughtProgressionDedupTicks>2500</thoughtProgressionDedupTicks>
    <thoughtProgressionRules>
      <li>
        <categoryKey>food</categoryKey>
        <thoughtDefName>NeedFood</thoughtDefName>
        <stages>
          <li><stageIndex>2</stageIndex><severity>1</severity></li> <!-- malnourished -->
          <li><stageIndex>3</stageIndex><severity>2</severity></li> <!-- badly malnourished -->
          <li><stageIndex>4</stageIndex><severity>3</severity></li> <!-- starving -->
          <li><stageIndex>5</stageIndex><severity>4</severity></li> <!-- advanced starvation -->
          <li><stageIndex>6</stageIndex><severity>5</severity></li> <!-- extreme starvation -->
        </stages>
      </li>
      <li>
        <categoryKey>rest</categoryKey>
        <thoughtDefName>NeedRest</thoughtDefName>
        <stages>
          <li><stageIndex>1</stageIndex><severity>1</severity></li> <!-- tired -->
          <li><stageIndex>2</stageIndex><severity>2</severity></li> <!-- exhausted -->
        </stages>
      </li>
      <li>
        <categoryKey>outdoors</categoryKey>
        <thoughtDefName>NeedOutdoors</thoughtDefName>
        <stages>
          <li><stageIndex>1</stageIndex><severity>1</severity></li> <!-- trapped underground -->
          <li><stageIndex>0</stageIndex><severity>2</severity></li> <!-- entombed underground -->
        </stages>
      </li>
      <li>
        <categoryKey>chemical</categoryKey>
        <thoughtDefName>DrugDesireInterest</thoughtDefName>
        <stages>
          <li><stageIndex>1</stageIndex><severity>1</severity></li> <!-- chemical hunger -->
          <li><stageIndex>2</stageIndex><severity>2</severity></li> <!-- chemical starvation -->
        </stages>
      </li>
      <li>
        <categoryKey>chemical</categoryKey>
        <thoughtDefName>DrugDesireFascination</thoughtDefName>
        <stages>
          <li><stageIndex>1</stageIndex><severity>1</severity></li> <!-- chemical hunger -->
          <li><stageIndex>2</stageIndex><severity>2</severity></li> <!-- chemical starvation -->
        </stages>
      </li>
    </thoughtProgressionRules>

    <!-- Hediff progression scan. New hediffs are caught by AddHediff; this slow scan only watches
         matched active hediffs for XML-configured severity-step increases. -->
    <hediffProgressionScanIntervalTicks>2500</hediffProgressionScanIntervalTicks>

    <!-- Work diary sampling. Work has no one-shot event hook, so the mod periodically samples
         current colonist jobs, then applies chance and cooldown gates. -->
    <workScanIntervalTicks>2500</workScanIntervalTicks>
    <workBaseChance>0.08</workBaseChance>
    <workSameTypeCooldownTicks>180000</workSameTypeCooldownTicks>
    <workRecentDifferentTypeMultiplier>0.5</workRecentDifferentTypeMultiplier>
    <workPassionChanceMultiplier>1.4</workPassionChanceMultiplier>
    <workNegativeChanceMultiplier>1.2</workNegativeChanceMultiplier>
    <workDarkStudyChanceMultiplier>1.5</workDarkStudyChanceMultiplier>
    <workLowSkillThreshold>4</workLowSkillThreshold>

    <!-- Day reflection (end-of-day summary). Set daySummaryEnabled false to fall back to the
         old per-source ambient notes. Weights are relative; raise one to make that kind of
         moment survive selection more often. -->
    <daySummaryEnabled>true</daySummaryEnabled>
    <daySummaryMaxHighlights>3</daySummaryMaxHighlights>
    <!-- Signal kinds that can justify creating a day reflection. Valid tokens:
         event, opinion, hediff, filler. Leave filler out to keep common batched events as
         background only; add it to allow quiet filler-only days to generate summaries. -->
    <daySummaryImportantSignalKinds>
      <li>event</li>
      <li>opinion</li>
      <li>hediff</li>
    </daySummaryImportantSignalKinds>
    <daySummaryOpinionDeltaThreshold>15</daySummaryOpinionDeltaThreshold>
    <daySummaryWeightCriticalEvent>1</daySummaryWeightCriticalEvent>
    <daySummaryWeightMajorEvent>0.7</daySummaryWeightMajorEvent>
    <daySummaryWeightHediff>0.8</daySummaryWeightHediff>
    <daySummaryWeightOpinionShift>0.6</daySummaryWeightOpinionShift>
    <daySummaryWeightFiller>0.15</daySummaryWeightFiller>
  </PawnDiary.DiaryTuningDef>

</Defs>
