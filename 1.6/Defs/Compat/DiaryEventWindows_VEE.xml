<?xml version="1.0" encoding="utf-8" ?>
<!--
  One-shot incident windows and their display groups for Vanilla Events Expanded
  (VanillaExpanded.VEE).

  How this works: Pawn Diary already observes every successful IncidentWorker.TryExecute. Each
  DiaryEventWindowDef below matches one or more exact VEE IncidentDef names, writes one immediate
  page, and then closes (timeoutTicks=-1 + keepActive=false means there is no guessed lingering
  state). recordScope=MapWitness asks the core event-window recorder for one deterministic eligible
  witness on the incident map, avoiding a page for every colonist. The matching Interaction-domain
  display group then gives that synthetic page a real label and voice before the core "other"
  catch-all at order 150.

  Both windows and display groups use the VanillaExpanded.VEE package gate. Exact plain-string
  matchers remain the content boundary, and the gate also keeps the display rows out of settings and
  discards any restored active window after VEE is removed. All names were rechecked against official
  VEE v2.01 commit 112f0324238b352dad8ca54aa0d2a391d10ec99a (2026-07-11).

  Considered and deliberately skipped:
    * VEE_HuntingParty, VEE_WildMenWanderIn, and VEE_WhiteoutRefugees — flavor/arrival events that
      do not warrant another guaranteed page.
    * VEE_Drought, VEE_LongNight, VEE_Scorch, VEE_Whiteout, VEE_PsychicBloom, VEE_PsychicHum,
      VEE_PsychicOverdrive, VEE_PsychicStimulation, and VEE_PsychicRain — their live conditions are
      covered by DiaryObservedConditions_VEE.xml, while normal game letters announce the start.
    * VEE_VisitorGroupRaid — it starts as a neutral visitor incident and turns hostile later through
      a hidden hediff; recording the incident execution as a betrayal would be false and premature.
    * Quest/event-chain plumbing and cargo/animal pod incidents — too routine or indirect for a
      guaranteed standalone page.
-->
<Defs>

  <PawnDiary.DiaryEventWindowDef>
    <defName>VeeEarthquake</defName>
    <label>VEE earthquake</label>
    <windowKey>VeeEarthquake</windowKey>
    <enabled>true</enabled>
    <enableWhenPackageIdsLoaded>
      <li>VanillaExpanded.VEE</li>
    </enableWhenPackageIdsLoaded>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
    <keepActive>false</keepActive>
    <recordScope>MapWitness</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the ground itself turning traitor beneath the pawn; stay inside the shaking, then count only damage the supplied facts actually show</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VeeEarthquake.Start</startTextKey>
    <startSignals>
      <li>
        <source>Incident</source>
        <signal>executed</signal>
        <matchDefNames>
          <li>VEE_Earthquake</li>
        </matchDefNames>
      </li>
    </startSignals>
    <promptEnabled>false</promptEnabled>
    <promptWeight>0</promptWeight>
  </PawnDiary.DiaryEventWindowDef>

  <PawnDiary.DiaryEventWindowDef>
    <defName>VeeMeteoriteShower</defName>
    <label>VEE meteorite shower</label>
    <windowKey>VeeMeteoriteShower</windowKey>
    <enabled>true</enabled>
    <enableWhenPackageIdsLoaded>
      <li>VanillaExpanded.VEE</li>
    </enableWhenPackageIdsLoaded>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
    <keepActive>false</keepActive>
    <recordScope>MapWitness</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write fire coming down from the sky with awe and danger mixed together; use only impacts, heat, or damage that the supplied facts support</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VeeMeteoriteShower.Start</startTextKey>
    <startSignals>
      <li>
        <source>Incident</source>
        <signal>executed</signal>
        <matchDefNames>
          <li>VEE_MeteoriteShower</li>
        </matchDefNames>
      </li>
    </startSignals>
    <promptEnabled>false</promptEnabled>
    <promptWeight>0</promptWeight>
  </PawnDiary.DiaryEventWindowDef>

  <PawnDiary.DiaryEventWindowDef>
    <defName>VeeSpaceBattle</defName>
    <label>VEE orbital disaster</label>
    <windowKey>VeeSpaceBattle</windowKey>
    <enabled>true</enabled>
    <enableWhenPackageIdsLoaded>
      <li>VanillaExpanded.VEE</li>
    </enableWhenPackageIdsLoaded>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
    <keepActive>false</keepActive>
    <recordScope>MapWitness</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write a war or wreck overhead that has nothing and everything to do with the colony; stay with what the pawn can see falling and never invent the combatants' story</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VeeSpaceBattle.Start</startTextKey>
    <startSignals>
      <li>
        <source>Incident</source>
        <signal>executed</signal>
        <matchDefNames>
