<?xml version="1.0" encoding="utf-8" ?>
<!--
  Lasting-condition prompt tints for Vanilla Events Expanded (VanillaExpanded.VEE).

  These defs do not create diary pages. Every 1,500 ticks Pawn Diary checks active conditions on
  player home maps; an exact defName match adds a small writing cue to entries made while that state
  lasts. The live GameCondition is the source of truth, so loading a save mid-event rediscovers it and
  clearing the condition removes the cue after the normal 2,500-tick debounce.

  DiaryObservedConditionDef has no package-gate field. Safety instead comes from exact plain-string
  matchers: without VEE none of these names can be active, so the defs remain inert and create no
  missing-def reference or warning. This is also safe when VEE's NoOdyssey folder changes available
  content. Source names were rechecked against official VEE v2.01 commit
  112f0324238b352dad8ca54aa0d2a391d10ec99a (2026-07-11).

  SpaceBattle is intentionally absent: it is short and covered by DiaryEventWindows_VEE.xml. VEE
  hediffs are also absent here because their parent conditions already supply the map-wide tint;
  observing both would double-weight the same event.
-->
<Defs>

  <PawnDiary.DiaryObservedConditionDef>
    <defName>VeeDroughtActive</defName>
    <label>VEE drought</label>
    <conditionKey>VeeDroughtActive</conditionKey>
    <enabled>true</enabled>
    <scope>Map</scope>
    <observerType>GameCondition</observerType>
    <pollIntervalTicks>1500</pollIntervalTicks>
    <startDebounceTicks>0</startDebounceTicks>
    <endDebounceTicks>2500</endDebounceTicks>
    <includeHomeMapsOnly>true</includeHomeMapsOnly>
    <matchDefNames>
      <li>VEE_Drought</li>
    </matchDefNames>
    <recordStartEvent>false</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <promptEnabled>true</promptEnabled>
    <promptWeight>4</promptWeight>
    <normalPromptWeightMultiplier>1</normalPromptWeightMultiplier>
    <promptDecayTicks>120000</promptDecayTicks>
    <promptDecayMinMultiplier>0.4</promptDecayMinMultiplier>
    <promptPriorityKey>PawnDiary.Prompt.ObservedCondition.VeeDroughtActive.Priority</promptPriorityKey>
    <promptConditionKey>PawnDiary.Prompt.ObservedCondition.VeeDroughtActive.Condition</promptConditionKey>
    <promptDescriptionKey>PawnDiary.Prompt.ObservedCondition.VeeDroughtActive.Description</promptDescriptionKey>
    <promptCueKeys>
      <li>PawnDiary.Prompt.ObservedCondition.VeeDroughtActive.Cue.Dust</li>
    </promptCueKeys>
  </PawnDiary.DiaryObservedConditionDef>

