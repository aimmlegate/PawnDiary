<?xml version="1.0" encoding="utf-8"?>
<!--
  Tuning surface for the pawn memory subsystem (design/MEMORY_SYSTEM_DESIGN.md §11): deposit,
  associative recall, and eviction knobs for per-pawn tagged/keyworded memory fragments. The pure
  extraction/selector/planner receive a copied MemoryPolicySnapshot, so editing this Def changes
  policy without letting Verse/Defs leak into the pure layer or its tests. Behavioral values mirror
  MemoryPolicySnapshot.CreateDefault exactly. The natural-language memoryContextInstruction is the
  intentional exception: its code fallback is blank, so deleting this file omits optional prompt
  guidance without changing selection/scoring behavior or hardcoding English in the fallback.

  STATUS: the memory layer ships INERT. Nothing snapshots this Def yet; it only becomes live when
  the capture/recall wiring (design §14 steps 4-7) lands.

  DLC-safety: rows are plain strings and numbers. DLC-sourced events (psychic rituals, royal
  titles, anomaly dread) match only when their colorCue/gameContext strings exist in a save;
  without the DLC those matchers sit inert. No DLC Def is referenced here.

  Localization: <label>, age-band labels, and memoryContextInstruction are prompt/UI prose and are
  translated via DefInjected (see Languages/Russian (Русский)/DefInjected/PawnDiary.DiaryMemoryTuningDef).
  Tag tokens and gameContext keys are stable schema values and stay English everywhere.
-->
<Defs>
  <PawnDiary.DiaryMemoryTuningDef>
    <defName>Diary_Memory</defName>
    <label>pawn memory policy</label>

    <enabled>true</enabled>

    <!-- Deposit: the noise gate keeps ambient chat and quiet pages out of the store (design §7). -->
    <minDepositImportance>0.3</minDepositImportance>
    <fragmentTextMaxChars>200</fragmentTextMaxChars>
    <maxKeywordsPerFragment>8</maxKeywordsPerFragment>
    <fallbackCueImportance>0.3</fallbackCueImportance>
    <importantGroupBonus>0.15</importantGroupBonus>
    <!-- Negativity bias is deliberate: bad memories stick more than good ones. -->
    <negativeMoodBonus>0.10</negativeMoodBonus>
    <positiveMoodBonus>0.05</positiveMoodBonus>

    <!-- Base importance by colorCue (design §7.3); empty/unknown cues use fallbackCueImportance. -->
    <cueImportance>
      <li><cue>extremeDark</cue><importance>0.9</importance></li>
      <li><cue>bodyPartLost</cue><importance>0.85</importance></li>
      <li><cue>danger</cue><importance>0.8</importance></li>
      <li><cue>combat</cue><importance>0.75</importance></li>
      <li><cue>mentalBreak</cue><importance>0.7</importance></li>
      <li><cue>bodyPartAnomalous</cue><importance>0.7</importance></li>
      <li><cue>psychic</cue><importance>0.65</importance></li>
      <li><cue>bodyPartArtificial</cue><importance>0.6</importance></li>
      <li><cue>royalty</cue><importance>0.6</importance></li>
      <li><cue>socialFight</cue><importance>0.55</importance></li>
      <li><cue>white</cue><importance>0.5</importance></li>
      <li><cue>daze</cue><importance>0.5</importance></li>
      <li><cue>strangeChat</cue><importance>0.35</importance></li>
      <li><cue>quiet</cue><importance>0.2</importance></li>
    </cueImportance>

    <!-- colorCue -> tags. Values come from the closed MemoryTagTokens vocabulary; unknown tokens
         are dropped at extraction time rather than deposited, so a typo here cannot invent a tag. -->
    <cueTags>
      <li><cue>combat</cue><tags><li>combat</li></tags></li>
      <li><cue>danger</cue><tags><li>combat</li><li>danger</li></tags></li>
      <li><cue>socialFight</cue><tags><li>conflict</li><li>social</li></tags></li>
      <li><cue>mentalBreak</cue><tags><li>breakdown</li></tags></li>
      <li><cue>extremeDark</cue><tags><li>dread</li></tags></li>
      <li><cue>strangeChat</cue><tags><li>dread</li><li>social</li></tags></li>
      <li><cue>bodyPartLost</cue><tags><li>body</li><li>illness</li></tags></li>
      <li><cue>bodyPartAnomalous</cue><tags><li>body</li><li>illness</li></tags></li>
      <li><cue>bodyPartArtificial</cue><tags><li>body</li><li>illness</li></tags></li>
      <li><cue>psychic</cue><tags><li>psychic</li></tags></li>
      <li><cue>royalty</cue><tags><li>royalty</li></tags></li>
      <li><cue>white</cue><tags><li>joy</li></tags></li>
      <li><cue>daze</cue><tags><li>breakdown</li></tags></li>
      <li><cue>quiet</cue><tags /></li>
    </cueTags>

    <!-- gameContext marker -> tags. "key=" means "present with a meaningful value" and ignores the
         saved sentinel words none/n/a/unknown, so royal_title=none never tags a memory as royal. -->
    <contextMarkerTags>
      <li><marker>ritual=</marker><tags><li>ritual</li></tags></li>
      <li><marker>psychic_ritual=</marker><tags><li>ritual</li><li>psychic</li></tags></li>
      <li><marker>royal_title=</marker><tags><li>royalty</li></tags></li>
    </contextMarkerTags>

    <!-- gameContext keys whose VALUES become association keywords (design §7.3 step 2). -->
    <contextKeywordKeys>
      <li>weapon</li>
      <li>royal_title</li>
      <li>ideological_role</li>
      <li>quest_name</li>
      <li>animal_name</li>
      <li>room</li>
      <li>place</li>
    </contextKeywordKeys>

    <!-- Retrieval (design §8): seeded gates keep memories occasional seasoning, never every page. -->
    <minFragmentsForRecall>4</minFragmentsForRecall>
    <recallGateChance>0.6</recallGateChance>
    <tagWeight>0.4</tagWeight>
    <keywordWeight>0.6</keywordWeight>
    <!-- Two shared tags / three shared keywords saturate the overlap scores. -->
    <tagSaturationCount>2</tagSaturationCount>
    <keywordSaturationCount>3</keywordSaturationCount>
    <!-- Half a RimWorld year half-life with a floor: old memories fade but never vanish. -->
    <recencyHalfLifeTicks>1800000</recencyHalfLifeTicks>
    <recencyFloor>0.25</recencyFloor>
    <!-- Never echo this morning: same-day fragments score zero. -->
    <minRecallAgeTicks>60000</minRecallAgeTicks>
    <minDirectScore>0.30</minDirectScore>
    <spreadGateChance>0.5</spreadGateChance>
    <spreadDamping>0.5</spreadDamping>
    <minSpreadScore>0.15</minSpreadScore>
    <!-- Anti-repetition: a fragment recalled inside this window scores at quarter strength. -->
    <recallCooldownTicks>300000</recallCooldownTicks>
    <repetitionPenaltyFactor>0.25</repetitionPenaltyFactor>
    <memoryContextMaxChars>500</memoryContextMaxChars>
    <!-- Universal whole-line ceiling for the memory prompt block: whole picks are dropped
         (associative first), never truncated mid-memory (LORE_MEMORY_SEED_PLAN §9). -->
    <memoryContextMaxLines>2</memoryContextMaxLines>

    <!-- Authored lore-seed memories (LORE_MEMORY_SEED_PLAN §13). loreSeedsEnabled is the XML
         half of the gate; the player's enableLoreSeeds setting is ANDed in by the adapter.
         The narrative-age offset (two in-game years) affects only the rendered age band and the
         minimum-age guard, and is clamped to the pawn's biological age at deposit. -->
    <loreSeedsEnabled>true</loreSeedsEnabled>
    <maxInitialLoreSeedsPerPawn>4</maxInitialLoreSeedsPerPawn>
    <minSpecificInitialLoreSeedsPerPawn>1</minSpecificInitialLoreSeedsPerPawn>
    <loreSeedOrdinaryImportance>0.35</loreSeedOrdinaryImportance>
    <loreSeedCoreImportance>0.85</loreSeedCoreImportance>
    <loreSeedNarrativeAgeOffsetTicks>7200000</loreSeedNarrativeAgeOffsetTicks>
    <maxCoreLoreSeedsPerPawnLifetime>2</maxCoreLoreSeedsPerPawnLifetime>
    <!-- 20 RimWorld days: a surfaced core identity seed stays ineligible this long. -->
    <coreLoreRecallCooldownTicks>1200000</coreLoreRecallCooldownTicks>
    <maxProgressionLoreSeedsPerPawnLifetime>4</maxProgressionLoreSeedsPerPawnLifetime>

    <!-- Age -> label bands, evaluated in order; the last row is the "else" catch-all. Labels reach
         the LLM prompt, so translations override them via DefInjected. -->
    <ageBands>
      <li><maxAgeTicks>300000</maxAgeTicks><label>a few days ago</label></li>
      <li><maxAgeTicks>900000</maxAgeTicks><label>a couple of weeks ago</label></li>
      <li><maxAgeTicks>3600000</maxAgeTicks><label>a few quadrums ago</label></li>
      <li><maxAgeTicks>2147483647</maxAgeTicks><label>a long time ago</label></li>
    </ageBands>

    <!-- Prompt guidance line, prepended to the recalled memory lines when any surface. -->
    <memoryContextInstruction>Long-standing memories that drift into mind while writing. Weave in at most one, briefly and only if it feels natural; these are the past, not today's events.</memoryContextInstruction>

    <!-- Eviction (design §10): recalled memories stay alive; forgotten ordinary ones fade out. -->
    <maxFragmentsPerPawn>60</maxFragmentsPerPawn>
    <coreImportanceThreshold>0.8</coreImportanceThreshold>
    <maxCoreFragmentsPerPawn>15</maxCoreFragmentsPerPawn>
    <retentionHalfLifeTicks>1800000</retentionHalfLifeTicks>
    <staleEvictTicks>7200000</staleEvictTicks>
    <maxTotalFragments>3000</maxTotalFragments>
    <deadOwnerGraceTicks>3600000</deadOwnerGraceTicks>
    <memoryEvictionScanIntervalTicks>150000</memoryEvictionScanIntervalTicks>
  </PawnDiary.DiaryMemoryTuningDef>
</Defs>
