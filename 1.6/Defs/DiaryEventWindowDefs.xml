    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's heart attack as immediate bodily danger; keep it personal, physical, and urgent without inventing treatment outcomes</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.HeartAttack.Start</startTextKey>

    <startSignals>
