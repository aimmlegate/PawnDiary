<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--
    Generic event-window example:
    - source can be Incident, Quest, ThingSpawned, Letter, ProximityLetter, VoidMonolith,
      PawnAge, Hediff, or PrisonBreak today.
    - signal examples: executed, accepted, completed, failed, spawned, received, birthday, added.
    - matchDefNames are plain strings, so DLC/modded content is safe when absent.

    To watch a mech cluster, add another PawnDiary.DiaryEventWindowDef with:
      <source>Incident</source>
      <signal>executed</signal>
      <matchDefNames><li>MechCluster</li></matchDefNames>

    To watch any accepted quest, use:
      <source>Quest</source>
      <signal>accepted</signal>

    To watch a stable vanilla letter key, use:
      <source>Letter</source>
      <signal>received</signal>
      <matchDefNames><li>SomeLetterMessageKey</li></matchDefNames>

    To watch a ThingComp proximity letter, match the parent ThingDef:
      <source>ProximityLetter</source>
      <signal>received</signal>
      <matchDefNames><li>SomeThingDef</li></matchDefNames>

    To watch a completed void monolith activation, use:
      <source>VoidMonolith</source>
      <signal>activated</signal>

    To watch a specific hediff appearing on one pawn, use:
      <source>Hediff</source>
      <signal>added</signal>
      <matchDefNames><li>SomeHediffDef</li></matchDefNames>
  -->

  <!-- The former MetalhorrorSuspicion event window was retired in favor of the Plan 12 observed
       condition "AnomalyGrayFleshEvidence" (1.6/Defs/DiaryObservedConditionDefs.xml). A fixed
       timeout could never prove the suspicion was still unresolved; the observed condition instead
       stays active exactly while gray-flesh evidence is physically present on the map. -->

  <PawnDiary.DiaryEventWindowDef>
    <defName>VoidMonolithDiscovery</defName>
    <label>void monolith discovery</label>
    <windowKey>VoidMonolithDiscovery</windowKey>
    <enabled>true</enabled>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
    <keepActive>false</keepActive>
    <recordScope>SubjectPawn</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's first discovery of the void monolith as extreme dark anomaly dread; make the structure feel inhuman and psychic, but keep the moment grounded in what the pawn can see and feel</instruction>
    <colorCue>extremeDark</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VoidMonolithDiscovery.Start</startTextKey>

    <startSignals>
      <li>
        <source>ProximityLetter</source>
        <signal>received</signal>
        <matchDefNames>
          <li>VoidMonolith</li>
        </matchDefNames>
      </li>
    </startSignals>

    <promptEnabled>false</promptEnabled>
    <promptWeight>0</promptWeight>
  </PawnDiary.DiaryEventWindowDef>

  <PawnDiary.DiaryEventWindowDef>
    <defName>VoidMonolithActivation</defName>
    <label>void monolith activation</label>
    <windowKey>VoidMonolithActivation</windowKey>
    <enabled>true</enabled>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
    <keepActive>false</keepActive>
    <recordScope>SubjectPawn</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's completed interaction with the void monolith as extreme dark anomaly dread; focus on the psychic pressure, the structure changing, and the sense that something beyond the colony has noticed</instruction>
    <colorCue>extremeDark</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VoidMonolithActivation.Start</startTextKey>

    <startSignals>
      <li>
        <source>VoidMonolith</source>
        <signal>activated</signal>
      </li>
    </startSignals>

    <promptEnabled>false</promptEnabled>
    <promptWeight>0</promptWeight>
  </PawnDiary.DiaryEventWindowDef>

  <PawnDiary.DiaryEventWindowDef>
