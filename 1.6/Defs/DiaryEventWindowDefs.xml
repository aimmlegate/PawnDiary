    <promptDescriptionKey>PawnDiary.Prompt.EventWindow.SelfTameJoined.Description</promptDescriptionKey>
    <promptCueKeys>
      <li>PawnDiary.Prompt.EventWindow.SelfTameJoined.Cue.Chosen</li>
    </promptCueKeys>
  </PawnDiary.DiaryEventWindowDef>

</Defs>
