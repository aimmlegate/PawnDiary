    <promptEnabled>true</promptEnabled>
    <promptWeight>3</promptWeight>
    <normalPromptWeightMultiplier>1</normalPromptWeightMultiplier>
    <promptDecayTicks>7500</promptDecayTicks>
    <promptDecayMinMultiplier>0.3</promptDecayMinMultiplier>
    <promptPriorityKey>PawnDiary.Prompt.EventWindow.ShortCircuitAftermath.Priority</promptPriorityKey>
    <promptConditionKey>PawnDiary.Prompt.EventWindow.ShortCircuitAftermath.Condition</promptConditionKey>
    <promptDescriptionKey>PawnDiary.Prompt.EventWindow.ShortCircuitAftermath.Description</promptDescriptionKey>
    <promptCueKeys>
      <li>PawnDiary.Prompt.EventWindow.ShortCircuitAftermath.Cue.Burnt</li>
    </promptCueKeys>
  </PawnDiary.DiaryEventWindowDef>

