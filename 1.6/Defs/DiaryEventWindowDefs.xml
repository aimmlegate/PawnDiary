    <restartOnStart>false</restartOnStart>
    <keepActive>true</keepActive>
    <recordScope>Map</recordScope>
    <recordStartEvent>false</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
