    <recordScope>SubjectPawn</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's deliberate first stirring of the void monolith as a threshold crossed; focus on the activator's visible and psychic experience, and do not invent what the monolith will cause next</instruction>
    <colorCue>anomalyDeep</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.VoidMonolithActivation.Start</startTextKey>

    <startSignals>
      <li>
        <source>VoidMonolith</source>
        <signal>activated</signal>
        <matchDefNames>
          <li>Stirring</li>
        </matchDefNames>
      </li>
    </startSignals>

    <!-- One primary monolith campaign exists in current vanilla saves, so epoch 0 is a stable
         per-save arc identity. A later source-owned reset/restart feature may introduce higher epochs
         without rewriting these already-saved references. -->
    <narrativeEvidence>
      <facet>journey_chapter</facet>
      <phase>stirring</phase>
      <arcKey>anomaly-monolith|0</arcKey>
      <salience>major</salience>
      <beliefTopics>
        <li>monolith</li>
        <li>void</li>
        <li>escalation</li>
      </beliefTopics>
    </narrativeEvidence>

    <promptEnabled>false</promptEnabled>
    <promptWeight>0</promptWeight>
  </PawnDiary.DiaryEventWindowDef>

