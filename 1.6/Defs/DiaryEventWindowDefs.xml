    <label>ancient danger</label>
    <windowKey>AncientDanger</windowKey>
    <enabled>true</enabled>
    <timeoutTicks>-1</timeoutTicks>
    <dedupTicks>2500</dedupTicks>
    <restartOnStart>false</restartOnStart>
