    <recordScope>SubjectPawn</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's immediate foreboding at the ancient wall as one personal moment; keep the danger uncertain and do not reveal what is inside</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.AncientDanger.Start</startTextKey>

