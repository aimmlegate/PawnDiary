    <recordScope>SubjectPawn</recordScope>
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordEndWithoutActive>false</recordEndWithoutActive>
    <recordTimeoutEvent>false</recordTimeoutEvent>
    <instruction>write the pawn's birthday as an uneasy RimWorld milestone, not a celebration; focus on age, fragility, and what another year can cost on the rim</instruction>
    <colorCue>danger</colorCue>
    <startTextKey>PawnDiary.Event.EventWindow.Birthday.Start</startTextKey>

    <startSignals>
