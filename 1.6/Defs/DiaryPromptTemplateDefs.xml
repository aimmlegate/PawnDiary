<?xml version="1.0" encoding="utf-8"?>
<!--
  Prompt templates control the structured fields sent to the LLM for each event shape.
  `source` values are stable internal tokens; `label` is the model-facing field name.
  System prompts and final instructions may be overridden here. When blank, DiaryPromptDef.xml
  supplies the shared default text.
-->
<Defs>

  <PawnDiary.DiaryPromptTemplateDef>
    <defName>DiaryPromptTemplate_PairDefault</defName>
    <templateKey>PairDefault</templateKey>
    <fields>
      <li><label>event</label><source>EventNoun</source></li>
      <li><label>pov</label><source>PovName</source></li>
      <li><label>role</label><source>PovRole</source></li>
      <li><label>with</label><source>OtherPawnName</source></li>
      <li><label>what you saw</label><source>PovText</source></li>
      <li><label>instruction</label><source>Instruction</source></li>
      <li><label>persona</label><source>Persona</source></li>
      <li><label>important health</label><source>PromptEnchantment</source></li>
      <li><label>setting</label><source>Setting</source></li>
      <li><label>relationship</label><source>Relationship</source></li>
      <li><label>my last opener (not repeat)</label><source>LastOpener</source></li>
    </fields>
  </PawnDiary.DiaryPromptTemplateDef>

