<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Phase 0 contains only primitive values and exact string identifiers. There are deliberately
       no Royalty Def references, so this policy loads safely when the DLC is absent. -->
  <PawnDiary.DiaryRoyaltyPolicyDef>
    <defName>Diary_Royalty</defName>
    <label>Royalty persona and progression policy</label>
    <enabled>true</enabled>
    <separationThresholdTicks>60000</separationThresholdTicks>
    <reconciliationCadenceTicks>2500</reconciliationCadenceTicks>
    <maximumSelectedTraits>2</maximumSelectedTraits>
    <maximumTraitCandidates>32</maximumTraitCandidates>
    <maximumTraitLabelCharacters>80</maximumTraitLabelCharacters>
    <maximumTraitDescriptionCharacters>240</maximumTraitDescriptionCharacters>
    <maximumDutyCategoryTokens>2</maximumDutyCategoryTokens>
    <titleCorrelationTicks>2500</titleCorrelationTicks>
    <psylinkCorrelationTicks>2500</psylinkCorrelationTicks>
    <titleThoughtCorrelationTicks>2500</titleThoughtCorrelationTicks>
    <!-- Cleanup lifetime for same-action exact-edge duplicates. A committed succession itself stays
         pending until its title chain reaches the target or contradictory title evidence retires it. -->
    <successionCorrelationTicks>2500</successionCorrelationTicks>
    <maximumPendingRoyalMutations>64</maximumPendingRoyalMutations>
    <maximumPendingTitleThoughts>128</maximumPendingTitleThoughts>
    <maximumPendingSuccessions>64</maximumPendingSuccessions>
    <maximumRoyaltyContextCharacters>120</maximumRoyaltyContextCharacters>
    <!-- Pawn.Kill emits a persona trait's kill memory and its Tale synchronously. Keep this small:
         it exists only to tolerate Harmony callback ordering, never to claim later ordinary thoughts. -->
    <killThoughtCorrelationTicks>60</killThoughtCorrelationTicks>
    <killThoughtWeight>100</killThoughtWeight>
    <bondedThoughtWeight>70</bondedThoughtWeight>
    <bondedHediffWeight>60</bondedHediffWeight>
    <equippedHediffWeight>40</equippedHediffWeight>
    <!-- Compatibility corrections remain weaker than event-specific structural evidence. -->
    <exactOverrideMaximumWeight>50</exactOverrideMaximumWeight>

    <!-- DefInjected prompt prose. {0}=pawn, {1}=persona weapon or title, {2}=faction. -->
    <personaNarrativeFormat>{0}&apos;s exact persona-weapon bond with {1} remains part of this moment.</personaNarrativeFormat>
    <titleNarrativeFormat>{0} currently holds the exact royal title {1} of {2}.</titleNarrativeFormat>
    <titleWithDutiesNarrativeFormat>{0} currently holds the exact royal title {1} of {2}; that rank also carries active court duties.</titleWithDutiesNarrativeFormat>

    <!-- Exact Tale defName strings only. The later adapter must still prove the killer/victim roles
         through Tale death metadata; these rows never infer a role from list position. -->
    <qualifyingTales>
      <li>
        <taleDefName>KilledMajorThreat</taleDefName>
        <killerRoleToken>initiator</killerRoleToken>
        <victimRoleToken>recipient</victimRoleToken>
        <minimumSignificance>1</minimumSignificance>
        <requireVictimDeath>true</requireVictimDeath>
      </li>
    </qualifyingTales>

    <!-- Ordinary double-pawn Tales which vanilla may record in the same Pawn.Kill call before or
         after KilledMajorThreat. They are staged only inside that exact call and released unchanged
         unless the milestone is accepted, so ordinary kills and disabled output keep vanilla flow. -->
    <personaKillCompanionTales>
      <li><taleDefName>KilledChild</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledColonist</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledColonyAnimal</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledMortar</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledLongRange</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledMelee</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>DefeatedHostileFactionLeader</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
      <li><taleDefName>KilledCapacity</taleDefName><killerRoleToken>initiator</killerRoleToken><victimRoleToken>recipient</victimRoleToken></li>
    </personaKillCompanionTales>

    <!-- Worker mappings and exact mod compatibility overrides are intentionally empty until an
         installed structural worker or mod requires an explicit, reviewed mapping. -->
    <traitWorkerRules />
    <traitOverrides />

    <!-- Exact DLC identifiers remain plain strings. Missing Royalty content simply never invokes
         these matchers; there is no DefDatabase or XML Def cross-reference. -->
    <bestowingRitualDefNames>
      <li>BestowingCeremony</li>
    </bestowingRitualDefNames>
    <animaRitualDefNames>
      <li>AnimaTreeLinking</li>
    </animaRitualDefNames>
    <neuroformerThingDefNames>
      <li>PsychicAmplifier</li>
    </neuroformerThingDefNames>
  </PawnDiary.DiaryRoyaltyPolicyDef>
</Defs>
