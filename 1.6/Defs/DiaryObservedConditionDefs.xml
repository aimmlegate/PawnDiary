  <!-- Pass 6: replaces the disabled MetalhorrorSuspicion event window. While an analyzable sample
       remains on a map, suspicion colors prompts as fear of an unknown thing that infects and imitates
       people. Once a visible metalhorror has emerged, suppressWhenThingDefNames makes this observer
       report the sample as absent so the suspicion condition ends and the revealed-threat condition
       takes over. matchDefNames are Anomaly content, so this whole def stays inert without the Anomaly
       DLC. -->
  <PawnDiary.DiaryObservedConditionDef>
    <defName>AnomalyGrayFleshEvidence</defName>
    <label>imitator infection evidence</label>
    <conditionKey>AnomalyGrayFleshEvidence</conditionKey>
    <enabled>true</enabled>
    <scope>Map</scope>
    <observerType>ThingPresent</observerType>
    <!-- Thing scans are more expensive than reading a danger rating; poll conservatively. -->
    <pollIntervalTicks>2500</pollIntervalTicks>
    <startDebounceTicks>0</startDebounceTicks>
    <endDebounceTicks>0</endDebounceTicks>
    <!-- If no metalhorror emerges, stop pushing this suspicion forever; then cool down before restart. -->
    <maxActiveTicks>120000</maxActiveTicks>
    <restartCooldownTicks>120000</restartCooldownTicks>
    <includeHomeMapsOnly>true</includeHomeMapsOnly>
    <!-- Do not feed the ThingDef label into the prompt; the writing cue should be the paranoia, not the item name. -->
    <maxEvidenceLabels>0</maxEvidenceLabels>
    <maxEvidenceChars>160</maxEvidenceChars>
    <matchDefNames>
      <li>GrayFleshSample</li>
    </matchDefNames>
    <suppressWhenThingDefNames>
      <li>Metalhorror</li>
      <li>Filth_MetalhorrorDebris</li>
    </suppressWhenThingDefNames>

    <!-- One observable suspicion page when it first appears; no end page (absence of evidence
         or the revealed metalhorror taking over is not a quiet diary moment). colorCue keeps the entry
         visibly ominous. -->
    <recordStartEvent>true</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordScope>MapColonists</recordScope>
    <colorCue>anomalyDeep</colorCue>
    <instruction>write this as paranoia and fear that some unknown thing may be infecting people and imitating them; keep it grounded in what the pawn could suspect, make ordinary faces and voices feel untrustworthy, and never explain hidden game mechanics or identify a host</instruction>
    <startTextKey>PawnDiary.Event.ObservedCondition.AnomalyGrayFleshEvidence.Start</startTextKey>

    <promptEnabled>true</promptEnabled>
    <promptWeight>40</promptWeight>
    <!-- Strongly bias away from ordinary health/mood context while suspicion is live. -->
    <normalPromptWeightMultiplier>0</normalPromptWeightMultiplier>
    <promptDecayTicks>60000</promptDecayTicks>
    <promptDecayMinMultiplier>0.15</promptDecayMinMultiplier>
    <promptPriorityKey>PawnDiary.Prompt.ObservedCondition.AnomalyGrayFleshEvidence.Priority</promptPriorityKey>
    <promptConditionKey>PawnDiary.Prompt.ObservedCondition.AnomalyGrayFleshEvidence.Condition</promptConditionKey>
    <promptDescriptionKey>PawnDiary.Prompt.ObservedCondition.AnomalyGrayFleshEvidence.Description</promptDescriptionKey>
    <promptCueKeys>
    </promptCueKeys>
  </PawnDiary.DiaryObservedConditionDef>

  <!-- Pass 7: confirmed metalhorror emergence as a MAP-scoped ThingPresent observer. This matches the
       spawned visible Metalhorror ThingDef, not the hidden MetalhorrorImplant hediff on a host, so it
       does not reveal the infection before the game has shown the threat. -->
  <PawnDiary.DiaryObservedConditionDef>
    <defName>MetalhorrorEmergence</defName>
    <label>metalhorror emergence</label>
    <conditionKey>MetalhorrorEmergence</conditionKey>
    <enabled>true</enabled>
    <scope>Map</scope>
    <observerType>ThingPresent</observerType>
    <pollIntervalTicks>2500</pollIntervalTicks>
    <startDebounceTicks>0</startDebounceTicks>
    <endDebounceTicks>5000</endDebounceTicks>
    <!-- No maxActiveTicks/restartCooldownTicks here, on purpose. This observer's end trigger is the live
         Metalhorror ThingDef leaving map.listerThings, and that trigger is reliable: when a metalhorror
         dies it becomes a Corpse_Entity (a different def), so ThingsOfDef(Metalhorror) stops matching and
         the end-debounce releases the override shortly after the kill. That lets a multi-day rampage keep
         the override live as long as any metalhorror is actually on the map. The separate cap-and-cooldown
         safety net IS still needed on AnomalyGrayFleshEvidence, because gray-flesh samples can linger as
         plain items after the situation resolves; see MetalhorrorInfection below for the post-emergence
         "still infected colonists" case. -->
    <matchDefNames>
      <li>Metalhorror</li>
    </matchDefNames>

    <recordStartEvent>false</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordScope>MapColonists</recordScope>
    <colorCue>anomalyDeep</colorCue>

    <promptEnabled>true</promptEnabled>
    <promptWeight>60</promptWeight>
    <normalPromptWeightMultiplier>0</normalPromptWeightMultiplier>
    <promptDecayTicks>60000</promptDecayTicks>
    <promptDecayMinMultiplier>0.35</promptDecayMinMultiplier>
    <promptPriorityKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorEmergence.Priority</promptPriorityKey>
    <promptConditionKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorEmergence.Condition</promptConditionKey>
    <promptDescriptionKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorEmergence.Description</promptDescriptionKey>
    <promptCueKeys>
      <li>PawnDiary.Prompt.ObservedCondition.MetalhorrorEmergence.Cue.Threat</li>
    </promptCueKeys>
  </PawnDiary.DiaryObservedConditionDef>

  <!-- Pass 8: hidden-infection "insurance" tone. MetalhorrorInfection (the hidden host hediff) is
       intentionally NOT revealed by PawnHediff (that observer skips hidden hediffs on purpose), but the
       metalhorror situation is not over just because the visible entity was killed: one metalhorror
       emerged from ONE host at roughly 50% colony infection, so other colonists can still be carrying the
       implant silently. This MapHiddenHediff observer senses that state as a single map-level boolean
       (is ANY home-map colonist infected?) WITHOUT ever naming a host or surfacing the hediff to the
       player or the LLM — it is a tone-only dread that the colony is not yet safe. It keeps the override
       alive after a kill while infection lingers, and releases cleanly when the colony is genuinely clean
       (a cured-or-dead host's hediffSet is really empty, so no cap is needed here). matchDefName is
       Anomaly content, so this whole def is inert without the Anomaly DLC. -->
  <PawnDiary.DiaryObservedConditionDef>
    <defName>MetalhorrorInfection</defName>
    <label>hidden imitator infection</label>
    <conditionKey>MetalhorrorInfection</conditionKey>
    <enabled>true</enabled>
    <scope>Map</scope>
    <observerType>MapHiddenHediff</observerType>
    <pollIntervalTicks>2500</pollIntervalTicks>
    <startDebounceTicks>0</startDebounceTicks>
    <endDebounceTicks>10000</endDebounceTicks>
    <includeHomeMapsOnly>true</includeHomeMapsOnly>
    <!-- Tone-only: never feed the hediff label into the prompt. The dread is the cue, not the diagnosis. -->
    <maxEvidenceLabels>0</maxEvidenceLabels>
    <matchDefNames>
      <li>MetalhorrorImplant</li>
    </matchDefNames>

    <recordStartEvent>false</recordStartEvent>
    <recordEndEvent>false</recordEndEvent>
    <recordScope>MapColonists</recordScope>
    <colorCue>anomalyDeep</colorCue>

    <promptEnabled>true</promptEnabled>
    <promptWeight>40</promptWeight>
    <!-- Suppress ordinary context while the colony is not yet clean, but softer than the open-threat
         override (which has weight 60). The two can overlap: while a metalhorror rampages AND colonists
         are infected, both fire and the stronger (Emergence) candidate wins the weighted pick. -->
    <normalPromptWeightMultiplier>0.3</normalPromptWeightMultiplier>
    <promptDecayTicks>60000</promptDecayTicks>
    <promptDecayMinMultiplier>0.5</promptDecayMinMultiplier>
    <promptPriorityKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorInfection.Priority</promptPriorityKey>
    <promptConditionKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorInfection.Condition</promptConditionKey>
    <promptDescriptionKey>PawnDiary.Prompt.ObservedCondition.MetalhorrorInfection.Description</promptDescriptionKey>
    <promptCueKeys>
      <li>PawnDiary.Prompt.ObservedCondition.MetalhorrorInfection.Cue.Distrust</li>
    </promptCueKeys>
  </PawnDiary.DiaryObservedConditionDef>

