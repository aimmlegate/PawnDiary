<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Trait identity and weight policy for psychotype rolls. Simple traits omit matchDegree;
       spectrum traits opt in and provide one rule per supported degree. Bonus targets are plain
       family names or psychotype defNames, so this remains safe without any paid DLC. -->
  <PawnDiary.DiaryPsychotypeTraitPolicyDef>
    <defName>Diary_PsychotypeTraitPolicy</defName>
    <gatedTakeoverChance>0.45</gatedTakeoverChance>
    <rules>
      <li><traitDefName>Psychopath</traitDefName><key>Psychopath</key>
        <familyBonuses><li><target>intense</target><bonus>6</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Hollow</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Ruthless</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Detached</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Cannibal</traitDefName><key>Cannibal</key>
        <familyBonuses><li><target>intense</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Ravenous</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Ruthless</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Bloodlust</traitDefName><key>Bloodlust</key>
        <familyBonuses><li><target>intense</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Bloodthirsty</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Volatile</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Jealous</traitDefName><key>Jealous</key>
        <familyBonuses><li><target>anxious</target><bonus>4</bonus></li><li><target>intense</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Resentful</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Narcissistic</target><bonus>4</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Greedy</traitDefName><key>Greedy</key>
        <familyBonuses><li><target>intense</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Ruthless</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Ambitious</target><bonus>4</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>TooSmart</traitDefName><key>TooSmart</key>
        <familyBonuses><li><target>inward</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Detached</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Wry</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>TorturedArtist</traitDefName><key>TorturedArtist</key>
        <familyBonuses><li><target>anxious</target><bonus>2</bonus></li><li><target>intense</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Resentful</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Nostalgic</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Theatrical</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Kind</traitDefName><key>Kind</key>
        <familyBonuses><li><target>grounded</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Content</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Dutiful</target><bonus>4</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Abrasive</traitDefName><key>Abrasive</key>
        <memberBonuses><li><target>DiaryPsychotype_Wry</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Pragmatic</target><bonus>2</bonus></li><li><target>DiaryPsychotype_Resentful</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Recluse</traitDefName><key>Recluse</key>
        <familyBonuses><li><target>inward</target><bonus>4</bonus></li><li><target>anxious</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Detached</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Avoidant</target><bonus>4</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>NaturalMood</traitDefName><matchDegree>true</matchDegree><degree>-2</degree><key>Depressive</key>
        <familyBonuses><li><target>anxious</target><bonus>4</bonus></li><li><target>inward</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Nostalgic</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Avoidant</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Resentful</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>NaturalMood</traitDefName><matchDegree>true</matchDegree><degree>-1</degree><key>Pessimist</key>
        <familyBonuses><li><target>anxious</target><bonus>2</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Resentful</target><bonus>2</bonus></li><li><target>DiaryPsychotype_Paranoid</target><bonus>2</bonus></li><li><target>DiaryPsychotype_Wry</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>NaturalMood</traitDefName><matchDegree>true</matchDegree><degree>1</degree><key>Optimist</key>
        <familyBonuses><li><target>grounded</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Content</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Ambitious</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>NaturalMood</traitDefName><matchDegree>true</matchDegree><degree>2</degree><key>Sanguine</key>
        <familyBonuses><li><target>grounded</target><bonus>6</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Content</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Wry</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Nerves</traitDefName><matchDegree>true</matchDegree><degree>-1</degree><key>Nervous</key>
        <familyBonuses><li><target>anxious</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Avoidant</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Dependent</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Nerves</traitDefName><matchDegree>true</matchDegree><degree>-2</degree><key>Volatile</key>
        <familyBonuses><li><target>intense</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Volatile</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Theatrical</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Neurotic</traitDefName><matchDegree>true</matchDegree><degree>1</degree><key>Neurotic</key>
        <familyBonuses><li><target>anxious</target><bonus>4</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Perfectionist</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Paranoid</target><bonus>2</bonus></li></memberBonuses>
      </li>
      <li><traitDefName>Neurotic</traitDefName><matchDegree>true</matchDegree><degree>2</degree><key>VeryNeurotic</key>
        <familyBonuses><li><target>anxious</target><bonus>6</bonus></li></familyBonuses>
        <memberBonuses><li><target>DiaryPsychotype_Perfectionist</target><bonus>6</bonus></li><li><target>DiaryPsychotype_Paranoid</target><bonus>4</bonus></li><li><target>DiaryPsychotype_Dependent</target><bonus>2</bonus></li></memberBonuses>
      </li>
    </rules>
  </PawnDiary.DiaryPsychotypeTraitPolicyDef>
</Defs>
