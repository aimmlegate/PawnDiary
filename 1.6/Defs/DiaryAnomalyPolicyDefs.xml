<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- A1-A2.2 policy. All identifiers are our own primitive strings; there are no Anomaly Def
       references, so this row safely loads and remains inert when the DLC is absent. -->
  <PawnDiary.DiaryAnomalyPolicyDef>
    <defName>Diary_AnomalyPolicy</defName>
    <label>Anomaly narrative policy</label>

    <studyEnabled>true</studyEnabled>
    <recordFirstStudyBreakthrough>true</recordFirstStudyBreakthrough>
    <recordCompletedEntityKind>true</recordCompletedEntityKind>
    <promotedStudyMilestones />
    <monolithKnowledgeMaxAgeTicks>60000</monolithKnowledgeMaxAgeTicks>
    <studyTaleSuppressionTicks>2500</studyTaleSuppressionTicks>

    <containmentEnabled>true</containmentEnabled>
    <containmentWitnessRadius>12</containmentWitnessRadius>
    <containmentMaxWriters>2</containmentMaxWriters>
    <containmentMaxEntityLabelsInContext>3</containmentMaxEntityLabelsInContext>
    <containmentDedupTicks>2500</containmentDedupTicks>
    <recentStudierMaxAgeTicks>60000</recentStudierMaxAgeTicks>

    <!-- A2.0 terminal outcomes emit at most one POV; A2.1 surgical disclosure and A2.2 ghoul
         transformation may pair exact roles. Retention is reserved; void remains for A3. -->
    <creepJoinerEnabled>true</creepJoinerEnabled>
    <creepJoinerOutcomeDedupTicks>2500</creepJoinerOutcomeDedupTicks>
    <creepJoinerArcRetentionTicks>3600000</creepJoinerArcRetentionTicks><!-- reserved; age-only pruning is inactive -->
    <creepJoinerMaxWitnesses>2</creepJoinerMaxWitnesses>
    <creepJoinerWitnessRadius>12</creepJoinerWitnessRadius>
    <ghoulTransformationEnabled>true</ghoulTransformationEnabled>
    <ghoulTransformationMaxWriters>2</ghoulTransformationMaxWriters>
    <ghoulTransformationDedupTicks>2500</ghoulTransformationDedupTicks>
    <voidOutcomeEnabled>true</voidOutcomeEnabled>
    <taleOwnershipMaxDepth>8</taleOwnershipMaxDepth>
    <taleOwnershipExpiryTicks>2500</taleOwnershipExpiryTicks>
  </PawnDiary.DiaryAnomalyPolicyDef>
</Defs>
