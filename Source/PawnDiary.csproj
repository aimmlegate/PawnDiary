<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>4d267dd4-d1f4-4662-86cd-50b68311a711</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>PawnDiary</RootNamespace>
    <AssemblyName>PawnDiary</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <LangVersion>7.3</LangVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- Managed DLL folder for RimWorld. Overridable via /p:RimWorldManaged=... or the
         RIMWORLD_MANAGED env var so the project builds from any checkout location, not only
         from inside RimWorld's Mods/ folder. -->
    <RimWorldManaged Condition="'$(RimWorldManaged)'=='' and '$(RIMWORLD_MANAGED)'!=''">$(RIMWORLD_MANAGED)</RimWorldManaged>
    <RimWorldManaged Condition="'$(RimWorldManaged)'==''">D:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed</RimWorldManaged>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>..\1.6\Assemblies\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>..\1.6\Assemblies\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="Assembly-CSharp">
      <HintPath>$(RimWorldManaged)\Assembly-CSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Harmony is a BUILD-TIME-ONLY reference (Private=False, so it is never copied to the output
         folder and never shipped). The Harmony runtime at game-time comes from the active
         brrainz.harmony mod, declared as a dependency in About/About.xml. Pawn Diary ships only its
         own PawnDiary.dll. (PackageReference/Lib.Harmony would be the modern idiom, but the legacy
         non-SDK csproj cannot be restored by the current .NET 10 / MSBuild 18 toolchain.) -->
    <Reference Include="0Harmony">
      <HintPath>Libs\0Harmony.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(RimWorldManaged)\UnityEngine.CoreModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>$(RimWorldManaged)\UnityEngine.IMGUIModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.TextRenderingModule">
      <HintPath>$(RimWorldManaged)\UnityEngine.TextRenderingModule.dll</HintPath>
      <Private>False</Private>
    </Reference>

    <Reference Include="System.Core"/>
    <Reference Include="System.Xml.Linq"/>
    <Reference Include="System.Data.DataSetExtensions"/>


    <Reference Include="Microsoft.CSharp"/>

    <Reference Include="System.Data"/>

    <Reference Include="System.Net.Http"/>

    <Reference Include="System.Xml"/>
  </ItemGroup>
  <ItemGroup>
    <!-- Compile every .cs under Source/ (recursively), skipping build intermediates. New files
         in any subfolder are picked up automatically — no need to edit this project file when
         you add one. -->
    <Compile Include="**\*.cs" Exclude="obj\**\*.cs;bin\**\*.cs" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- Single source of truth for the mod version: read About/About.xml <modVersion> and stamp it into
       the assembly at build time. The version attributes are intentionally absent from
       Properties/AssemblyInfo.cs; a generated file supplies them so bumping About.xml is the only
       place a release version changes (Debug and Release both pick it up). -->
  <Target Name="StampVersionFromAbout" BeforeTargets="CoreCompile">
    <XmlPeek XmlInputPath="$(MSBuildProjectDirectory)\..\About\About.xml" Query="/ModMetaData/modVersion/text()">
      <Output TaskParameter="Result" ItemName="_AboutModVersion" />
    </XmlPeek>
    <PropertyGroup>
      <_ModVersion>@(_AboutModVersion)</_ModVersion>
      <_ModVersion Condition="'$(_ModVersion)' == ''">0.0.0</_ModVersion>
      <_VersionSourceFile>$(IntermediateOutputPath)PawnDiaryVersion.g.cs</_VersionSourceFile>
    </PropertyGroup>
    <ItemGroup>
      <_VersionAttribute Include="System.Reflection.AssemblyVersionAttribute">
        <_Parameter1>$(_ModVersion)</_Parameter1>
      </_VersionAttribute>
      <_VersionAttribute Include="System.Reflection.AssemblyFileVersionAttribute">
        <_Parameter1>$(_ModVersion)</_Parameter1>
      </_VersionAttribute>
      <_VersionAttribute Include="System.Reflection.AssemblyInformationalVersionAttribute">
        <_Parameter1>$(_ModVersion)</_Parameter1>
      </_VersionAttribute>
    </ItemGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <WriteCodeFragment AssemblyAttributes="@(_VersionAttribute)" Language="C#" OutputFile="$(_VersionSourceFile)">
      <Output TaskParameter="OutputFile" ItemName="Compile" />
    </WriteCodeFragment>
  </Target>
</Project>
