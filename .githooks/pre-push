#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/.githooks/verify.ps1" -HookName pre-push
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$repo_root/.githooks/verify.ps1" -HookName pre-push
fi

exec powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/.githooks/verify.ps1" -HookName pre-push
