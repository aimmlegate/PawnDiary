<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Pawn Diary: 1-2-3 Personalities</name>
  <author>aimmlegate</author>
  <packageId>aimmlegate.pawndiary.adapter.personalities123</packageId>
  <modVersion IgnoreIfNoMatchingField="True">0.1.0</modVersion>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <!-- Both hard dependencies are load-order + assembly-resolution requirements, not just hints:
       - Pawn Diary owns the DiaryInteractionGroupDef type this mod's Defs are, and the integration API
         this mod's assembly calls.
       - 1-2-3 Personalities M1 owns SP_Module1.dll, which this mod's assembly references to read each
         colonist's Enneagram. Without M1 the assembly would fail to resolve, so it is a real dependency.
       Module 2 (the ThoughtDef/InteractionDef expansion) is OPTIONAL: it is only referenced by string
       package-id in XML, so the module-2 groups sit inert until it is installed. -->
  <modDependencies>
    <li>
      <packageId>aimmlegate.pawndiary.development</packageId>
      <displayName>Pawn Diary</displayName>
    </li>
    <li>
      <packageId>hahkethomemah.simplepersonalities</packageId>
      <displayName>1-2-3 Personalities M1</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2527258500</steamWorkshopUrl>
    </li>
  </modDependencies>
  <loadAfter>
    <li>aimmlegate.pawndiary.development</li>
    <li>hahkethomemah.simplepersonalities</li>
    <li>hahkethomemah.simplepersonalities.module2</li>
  </loadAfter>
  <description>Let your colonists' 1-2-3 Personalities show up in the way they remember and write.

Module 2's social moments get the right diary treatment, and each pawn's Enneagram can become a matching diary outlook. Use a built-in psychotype, editable text, or let your language model write one (experimental). Nothing is written back.

Requires Pawn Diary and 1-2-3 Personalities M1. Module 2 is optional but recommended.</description>
</ModMetaData>
