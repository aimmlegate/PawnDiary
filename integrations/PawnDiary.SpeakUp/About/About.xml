<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Pawn Diary: SpeakUp</name>
  <author>aimmlegate</author>
  <packageId>aimmlegate.pawndiary.adapter.speakup</packageId>
  <modVersion IgnoreIfNoMatchingField="True">0.1.0</modVersion>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <!-- Pawn Diary owns the Def type and integration API used here. SpeakUp is a hard dependency for
       normal installation because this adapter exists only to classify its interactions and observe
       its transient Talk objects. The code still guards every reflection target and the XML stays
       package-gated, so a force-loaded adapter fails inert instead of crashing when SpeakUp is absent. -->
  <modDependencies>
    <li>
      <packageId>aimmlegate.pawndiary</packageId>
      <displayName>Pawn Diary</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/3752041535</steamWorkshopUrl>
    </li>
    <li>
      <packageId>JPT.speakup</packageId>
      <displayName>SpeakUp</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2502518544</steamWorkshopUrl>
    </li>
  </modDependencies>
  <loadAfter>
    <li>aimmlegate.pawndiary</li>
    <li>JPT.speakup</li>
  </loadAfter>
  <description>Give SpeakUp conversations somewhere to live after the speech bubble disappears.

Jokes, deep talks, prisoner chats, reactions, and everyday chatter feed the right diary themes while keeping the lines pawns actually said. Longer exchanges can become one shared memory for both speakers, and you can turn that off in settings.

Requires Pawn Diary and SpeakUp.</description>
</ModMetaData>
