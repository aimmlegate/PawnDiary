<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Pawn Diary: Vanilla Social Interactions Expanded</name>
  <author>aimmlegate</author>
  <packageId>aimmlegate.pawndiary.adapter.vsie</packageId>
  <modVersion IgnoreIfNoMatchingField="True">0.2.0</modVersion>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <!-- Both mods are hard dependencies: Pawn Diary owns the DiaryInteractionGroupDef type, and this
       integration exists only to classify Vanilla Social Interactions Expanded content. The XML
       package gates remain as defensive guards if a player force-loads the integration anyway. -->
  <modDependencies>
    <li>
      <packageId>aimmlegate.pawndiary</packageId>
      <displayName>Pawn Diary</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/3752041535</steamWorkshopUrl>
    </li>
    <li>
      <packageId>VanillaExpanded.VanillaSocialInteractionsExpanded</packageId>
      <displayName>Vanilla Social Interactions Expanded</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2439736083</steamWorkshopUrl>
    </li>
  </modDependencies>
  <loadAfter>
    <li>aimmlegate.pawndiary</li>
    <li>VanillaExpanded.VanillaSocialInteractionsExpanded</li>
  </loadAfter>
  <description>Let the social stories from Vanilla Social Interactions Expanded make it into the diary.

Venting, teaching, insults, best-friend milestones, birthdays, funerals, and extra social moods each get a fitting place instead of falling into a generic conversation bucket.

Requires Pawn Diary and Vanilla Social Interactions Expanded.</description>
</ModMetaData>
