{
  "name": "pawndiary-error-endpoint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker + D1 ingest endpoint for Pawn Diary's opt-out error reporter.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply pawndiary_errors --remote",
    "db:migrate:local": "wrangler d1 migrations apply pawndiary_errors --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
